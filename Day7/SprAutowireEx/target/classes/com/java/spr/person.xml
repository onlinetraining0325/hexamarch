<beans xmlns = "http://www.springframework.org/schema/beans"
   xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance"
   xmlns:context = "http://www.springframework.org/schema/context"
   xsi:schemaLocation = "http://www.springframework.org/schema/beans
   http://www.springframework.org/schema/beans/spring-beans.xsd
   http://www.springframework.org/schema/context
   http://www.springframework.org/schema/context/spring-context.xsd">
   <context:annotation-config />
   <bean id="jobDetails" class="com.java.spr.JobDetails">
		<property name="job" value="Software Enginner" />
		<property name="company" value="Hexaware" />
		<property name="location" value="Chennai" />
	</bean>
	<bean id="personLingeshwar" class="com.java.spr.Person">
		<property name="id" value="1" />
		<property name="name" value="Lingeshwar" />
		<property name="family">
			<bean class="com.java.spr.Family">
				<property name="city" value="Coimbatore" />
				<property name="state" value="TaminNadu" />
			</bean>
		</property>
	</bean>
	
	<bean id="personMadesh" class="com.java.spr.Person">
		<property name="id" value="2" />
		<property name="name" value="Madesh" />
		<property name="family">
			<bean class="com.java.spr.Family">
				<property name="city" value="Coimbatore" />
				<property name="state" value="TaminNadu" />
			</bean>
		</property>
	</bean>
	
	<bean id="personDurga" class="com.java.spr.Person">
		<property name="id" value="3" />
		<property name="name" value="Durga" />
		<property name="family">
			<bean class="com.java.spr.Family">
				<property name="city" value="Selam" />
				<property name="state" value="TaminNadu" />
			</bean>
		</property>
	</bean>
</beans>